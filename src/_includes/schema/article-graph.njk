{% set breadcrumbItems = [] %}

{% set breadcrumbItems = breadcrumbItems | push({
    "@type": "ListItem",
    "position": 1,
    "name": "Главная",
    "item": site.url
}) %}

{% if page.url != "/" %}
  {% if page.url.startsWith("/articles/") %}
    {% set breadcrumbItems = breadcrumbItems | push({
        "@type": "ListItem",
        "position": 2,
        "name": "Статьи",
        "item": site.url + "/articles/"
    }) %}
    {% set breadcrumbItems = breadcrumbItems | push({
        "@type": "ListItem",
        "position": 3,
        "name": title,
        "item": site.url + page.url
    }) %}
  {% endif %}
{% endif %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "{{ site.url }}{{ page.url }}#webpage",
      "url": "{{ site.url | stripHtmlExtension }}{{ page.url | stripHtmlExtension }}",
      "name": "{{ title | safe }}",
      "description": "{{ description | safe }}",
      "inLanguage": "ru",
      "datePublished": "{{ date | date('yyyy-LL-dd\\'T\\'HH:mm:ssZZ') }}",
      "dateModified": "{{ last_modified_at | date('yyyy-LL-dd\\'T\\'HH:mm:ssZZ') }}",
      "publisher": {
        "@id": "{{ site.url }}#person"
      },
      "breadcrumb": {
        "@id": "{{ site.url }}{{ page.url }}#breadcrumb"
      },
      "mainEntity": {
        "@id": "{{ site.url }}{{ page.url }}#article"
      }
    },
    {
      "@type": "BlogPosting",
      "@id": "{{ site.url }}{{ page.url }}#article",
      "headline": "{{ title | safe }}",
      "url": "{{ site.url }}{{ page.url }}",
      "description": "{{ description | safe }}",
      "datePublished": "{{ page.date | date('yyyy-LL-dd\\'T\\'HH:mm:ssZZ') }}",
      "dateModified": "{{ last_modified_at | date('yyyy-LL-dd\\'T\\'HH:mm:ssZZ') }}",
      "author": {
        "@id": "{{ site.url }}#person"
      },
      "publisher": {
        "@id": "{{ site.url }}#person"
      },
      "mainEntityOfPage": {
        "@id": "{{ site.url }}{{ page.url }}#webpage"
      }{% if hasFAQ %},
      "hasPart": {
        "@id": "{{ site.url }}{{ page.url }}#faq"
      }{% endif %}
    },
    {
      "@type": "Person",
      "@id": "{{ site.url }}#person",
      "name": "Дмитрий Бартошевич"
    },
    {
      "@type": "BreadcrumbList",
      "@id": "{{ site.url }}{{ page.url }}#breadcrumb",
      "itemListElement": {{ breadcrumbItems | dump | safe }}
    }{% if hasFAQ %},
    {
      "@type": "FAQPage",
      "@id": "{{ site.url }}{{ page.url }}#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Можно ли использовать на Windows?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Да. Процесс установки: 1) Скачайте Ollama для Windows: https://ollama.com/download/windows 2) Запустите установщик 3) Откройте PowerShell или Command Prompt 4) Выполните: ollama pull llama3.1:8b 5) Создайте Modelfile (аналогично Linux-инструкции)"
          }
        },
        {
          "@type": "Question",
          "name": "Нужна ли видеокарта (GPU)?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Не обязательно, но желательно. Без GPU (только CPU): Llama 3.1 8B работает со скоростью ~15-20 токенов/сек (ответ за 10-20 сек). С NVIDIA GPU (8GB+ VRAM): Скорость возрастает в 5-10 раз (~100-200 токенов/сек, почти мгновенно). Для базового использования (чек-ины, декомпозиция) CPU достаточно."
          }
        },
        {
          "@type": "Question",
          "name": "Как клиент может сохранить историю диалогов?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Вручную. Варианты: Простой (копипаст): После важного диалога скопировать вывод терминала и вставить в текстовый файл. Автоматический (для продвинутых): ollama run depression-support | tee ~/mental-health-log-$(date +%Y-%m-%d).txt. НО: Для большинства клиентов с депрессией ручное сохранение — избыточная когнитивная нагрузка. Лучше не сохранять вообще."
          }
        },
        {
          "@type": "Question",
          "name": "Что делать, если клиент жалуется на медленные ответы?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Три варианта: 1) Использовать меньшую модель: ollama pull mistral:7b-instruct (быстрее Llama 3.1 8B, но чуть ниже качество) 2) Купить GPU: NVIDIA RTX 3060 (12GB) или выше — скорость возрастёт в 10 раз 3) Вернуться к облаку: Claude/ChatGPT с защитами (обезличивание, удаление через 30 дней)"
          }
        },
        {
          "@type": "Question",
          "name": "Безопасно ли это с точки зрения данных?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "При локальной установке: Данные НЕ отправляются в интернет, модель работает полностью офлайн, история хранится только на компьютере клиента, можно удалить всё: rm -rf ~/.ollama. НО: Компьютер клиента должен быть защищён: пароль на вход, шифрование диска (FileVault на macOS, LUKS на Linux), антивирус."
          }
        },
        {
          "@type": "Question",
          "name": "Можно ли использовать другие модели?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Да. Альтернативы Llama 3.1: Mistral 7B (быстрее, чуть менее эмпатична), Gemma 2 (9B) от Google (хороший русский), Phi-3 Medium (14B) качественнее, но медленнее. Команда для установки: ollama pull mistral:7b-instruct; ollama create my-model -f ~/modelfile"
          }
        }
      ]
    }{% endif %}
  ]
}
</script>
